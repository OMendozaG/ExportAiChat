{
  "manifest_version": 3,
  "name": "Chat Export AI",
  "description": "Export AI chats to TXT, HTML, MHT and PDF.",
  "version": "0.1.41",
  "icons": {
    "16": "src/assets/robot-download-16.png",
    "32": "src/assets/robot-download-32.png",
    "48": "src/assets/robot-download-48.png",
    "128": "src/assets/robot-download-128.png"
  },
  "permissions": [
    "storage",
    "downloads",
    "activeTab",
    "tabs",
    "pageCapture",
    "debugger"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*",
    "https://grok.com/*"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "https://grok.com/*"
      ],
      "js": [
        "src/shared/namespace.js",
        "src/shared/constants.js",
        "src/shared/default-settings.js",
        "src/shared/extension-bridge.js",
        "src/shared/storage.js",
        "src/shared/app-theme.js",
        "src/shared/button-system.js",
        "src/shared/sanitize.js",
        "src/shared/text-converter.js",
        "src/shared/post-process.js",
        "src/shared/export-engine.js",
        "src/providers/provider-registry.js",
        "src/providers/chatgpt-provider.js",
        "src/providers/claude-provider.js",
        "src/providers/gemini-provider.js",
        "src/providers/deepseek-provider.js",
        "src/providers/grok-provider.js",
        "src/content/ui-export-button.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Chat Export AI",
    "default_icon": {
      "16": "src/assets/robot-download-16.png",
      "32": "src/assets/robot-download-32.png",
      "48": "src/assets/robot-download-48.png",
      "128": "src/assets/robot-download-128.png"
    },
    "default_popup": "src/popup/popup.html"
  },
  "options_page": "src/options/options.html"
}
