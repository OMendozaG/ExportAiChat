{
  "manifest_version": 3,
  "name": "Chat Export AI",
  "description": "Export AI chats to TXT, HTML, MHT and PDF with a modular provider architecture.",
  "version": "0.1.9",
  "icons": {
    "16": "src/assets/robot-download.svg",
    "32": "src/assets/robot-download.svg",
    "48": "src/assets/robot-download.svg",
    "128": "src/assets/robot-download.svg"
  },
  "permissions": [
    "storage",
    "downloads",
    "activeTab",
    "tabs",
    "pageCapture",
    "debugger"
  ],
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "src/shared/namespace.js",
        "src/shared/constants.js",
        "src/shared/default-settings.js",
        "src/shared/chrome-helpers.js",
        "src/shared/storage.js",
        "src/shared/sanitize.js",
        "src/shared/text-converter.js",
        "src/shared/post-process.js",
        "src/shared/export-engine.js",
        "src/providers/provider-registry.js",
        "src/providers/chatgpt-provider.js",
        "src/content/ui-export-button.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Chat Export AI",
    "default_icon": {
      "16": "src/assets/robot-download.svg",
      "32": "src/assets/robot-download.svg",
      "48": "src/assets/robot-download.svg",
      "128": "src/assets/robot-download.svg"
    },
    "default_popup": "src/popup/popup.html"
  },
  "options_page": "src/options/options.html"
}
